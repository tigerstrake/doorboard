    "PresenceLabel": {
      "enum": [
        "available",
        "busy",
        "do_not_disturb",
        "sleeping",
        "at_class",
        "at_library",
        "away",
        "unknown"
      ],
      "title": "PresenceLabel",
      "type": "string"
    },
    "StatusPresenceChangedPayload": {
      "additionalProperties": false,
      "properties": {
        "label": {
