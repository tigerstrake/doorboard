            "manual",
            "focus_shortcut",
            "geofence_label",
            "calendar",
            "default"
          ],
          "title": "Source",
          "type": "string"
        },
        "subject_id": {
          "title": "Subject Id",
          "type": "string"
        },
        "until": {
          "anyOf": [
            {
              "$ref": "#/$defs/UTCDateTime"
            },
            {
