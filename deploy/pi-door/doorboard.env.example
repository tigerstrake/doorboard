# Door Pi only. Install as /etc/doorboard/doorboard.env mode 0600.
DOORBOARD_ENV=pi-door
DOORBOARD_DOOR_ID=primary
SSD_DATA_ROOT=/mnt/ssd/doorboard

DOOR_API_BIND=127.0.0.1:8080
DOOR_API_MEDIA_BASE_URL=http://127.0.0.1:8082
DOOR_API_MEDIA_PUBLIC_BASE_URL=http://127.0.0.1:8082
DOOR_API_SYNC_BASE_URL=http://127.0.0.1:8083
DOOR_API_SYNC_OUTBOX_MAX_ROWS=4096
DOOR_API_SYNC_TIMEOUT_S=1
DOOR_API_VISITOR_PUBLIC_BASE_URL=http://door.local
DOOR_API_VISITOR_TOKEN_SECRET=CHANGE_ME
DOOR_API_SOCIAL_ADMIN_TOKEN=CHANGE_ME

DOOR_VISIOND_BIND=127.0.0.1:8081
DOOR_VISIOND_ADMIN_TOKEN=CHANGE_ME
VISION_MODE=single-camera
SINGLE_CAMERA_MODE=true
VISIOND_ENROLLMENT_ROOT=/mnt/vision-enrollment/doorboard
VISIOND_REQUIRE_ENCRYPTED_STORAGE=true
VISIOND_CONSENT_STATEMENT_PATH=/opt/doorboard/docs/policies/consent-statement.md
DOOR_SYNC_BASE_URL=http://127.0.0.1:8083

DOOR_MEDIA_BIND=127.0.0.1:8082
DOOR_MEDIA_ADMIN_TOKEN=CHANGE_ME
MEDIA_MODE=mediamtx
MEDIAMTX_API=http://127.0.0.1:9997
DOOR_MEDIA_SEGMENT_RETENTION_S=3600
DOOR_MEDIA_SEGMENT_CLEANUP_INTERVAL_S=60
DOOR_MEDIA_MAX_ACTIVE_RECORDINGS=8
DOOR_MEDIA_MIN_FREE_BYTES=4294967296

DOOR_SYNC_BIND=127.0.0.1:8083
DOOR_SYNC_ADMIN_TOKEN=CHANGE_ME
CONTROL_PLANE_URL=http://nuc.local:8090
SYNC_INGEST_TOKEN=CHANGE_ME_INGEST_SCOPE_ONLY
SYNC_MEDIA_TARGET=nas
NAS_SYNC_TARGET=/mnt/nas/doorboard
SYNC_SYNCABLE_ROOTS=recordings,thumbnails

ESP32_TRANSPORT=uart
ESP32_UART_DEVICE=/dev/ttyAMA0
FEATURE_PHOTOBOOTH=false
