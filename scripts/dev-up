#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PYTHONPATH="$repo_root/apps/door-api/src:$repo_root/apps/door-media/src:$repo_root/apps/door-visiond/src:$repo_root/apps/simulator/src:$repo_root/packages/contracts/src${PYTHONPATH:+:$PYTHONPATH}"

uv run python -m doorboard_simulator panel "$@"
