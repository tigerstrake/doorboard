#!/usr/bin/env bash
set -euo pipefail

source "$(dirname "$0")/_uv-env"

pnpm_cmd=(pnpm)
if ! command -v pnpm >/dev/null 2>&1; then
  pnpm_cmd=(corepack pnpm)
fi

"$UV_PROJECT_ENVIRONMENT/bin/pyright" \
  --pythonpath "$UV_PROJECT_ENVIRONMENT/bin/python" \
  --project pyrightconfig.json
"$UV_PROJECT_ENVIRONMENT/bin/pyright" \
  --pythonpath "$UV_PROJECT_ENVIRONMENT/bin/python" \
  --project packages/pyrightconfig.json
"${pnpm_cmd[@]}" -r --if-present typecheck
