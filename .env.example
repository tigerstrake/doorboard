# Doorboard environment template.
# Copy to .env per host and fill in. NEVER commit real values.
# Per the trust model (ARCHITECTURE.md §Trust), the door Pi gets ONLY
# limited-scope credentials. NAS admin and Home Assistant admin secrets
# live on the NUC only.

# --- Shared ---
DOORBOARD_ENV=dev                # dev | pi-door | nuc
DOORBOARD_DOOR_ID=primary
TZ=America/Los_Angeles           # display boundary only; services use UTC internally

# --- Door Pi (limited credentials only) ---
DOOR_API_BIND=127.0.0.1:8080
DOOR_API_SYNC_BASE_URL=http://127.0.0.1:8083 # loopback: admin/private gallery projection
DOOR_VISIOND_BIND=127.0.0.1:8081
DOOR_MEDIA_BIND=127.0.0.1:8082
MEDIAMTX_API=http://127.0.0.1:9997
ESP32_TRANSPORT=uart             # uart | udp | mock
ESP32_UART_DEVICE=/dev/ttyAMA0
VISION_MODE=mock                 # disabled | mock | single-camera | dual-camera | hardware
SINGLE_CAMERA_MODE=true
SSD_DATA_ROOT=/mnt/ssd/doorboard
DOOR_VISIOND_ADMIN_TOKEN=        # bearer secret for /enroll,/unenroll,/privacy-mode; empty=disabled (dev/CI)
VISIOND_CONSENT_STATEMENT_PATH=  # optional path to consent-statement.md; empty uses the shipped v1 (ADR-0009 E-7)

# --- door-media Retention & Storage ---
DOOR_MEDIA_MIN_FREE_BYTES=4294967296          # Stop recording if free SSD space drops below 4 GiB
DOOR_MEDIA_MAX_RECORDING_BYTES=51539607552     # Global maximum SSD space for recordings (48 GiB)
DOOR_MEDIA_BELL_CLIP_MAX_AGE_S=259200          # Bell clip age cap (3 days)
DOOR_MEDIA_BELL_CLIP_MAX_SIZE_BYTES=10737418240 # Bell clip total size cap (10 GiB)
DOOR_MEDIA_VIDEO_MESSAGE_MAX_AGE_S=1209600      # Video message age cap (14 days)
DOOR_MEDIA_VIDEO_MESSAGE_MAX_SIZE_BYTES=32212254720 # Video message total size cap (30 GiB)
DOOR_MEDIA_PHOTO_BOOTH_MAX_AGE_S=604800        # Photo booth age cap (7 days)
DOOR_MEDIA_PHOTO_BOOTH_MAX_SIZE_BYTES=8589934592 # Photo booth total size cap (8 GiB)
DOOR_MEDIA_PHOTO_REVIEW_TTL_S=300              # Unsaved review captures are temporary (5 minutes)
DOOR_MEDIA_PHOTO_REVIEW_MAX_PENDING=16         # Bound in-memory/on-disk photo review queue
SYNC_UPLOAD_TOKEN=               # limited-scope upload token issued by NUC — NOT a NAS admin credential
CONTROL_PLANE_URL=http://nuc.local:8090

# --- door-sync (Pi → NUC/NAS upload bridge, T-502; limited credentials only) ---
DOOR_SYNC_BIND=127.0.0.1:8083
SYNC_INGEST_TOKEN=               # ingest-scoped NUC token: event mirror + person-purge (ADR-0009). Revocable.
NAS_SYNC_TARGET=                 # filesystem path of the mounted NAS share (limited service account); prod SFTP is deploy/nas
SYNC_MEDIA_TARGET=nas            # nas | mock (mock = no share, dev only)
DOOR_MEDIA_URL=http://127.0.0.1:8082   # loopback: reconcile + license local deletion
SYNC_SYNCABLE_ROOTS=recordings,thumbnails   # allowlist; visiond/ (biometrics) excluded by omission
DOOR_SYNC_ADMIN_TOKEN=           # local admin token gating GET /queue (empty = disabled in dev/CI)

# --- NUC (trusted control plane) ---
CONTROL_PLANE_BIND=0.0.0.0:8090
# Used when running control-plane-api standalone (outside infra/compose).
# Inside infra/compose/docker-compose.yml, this is instead built from
# POSTGRES_PASSWORD below and the `postgres` service hostname — the two
# stay independent so a bare-metal/dev run and the compose stack can differ.
POSTGRES_DSN=postgresql+psycopg://doorboard:CHANGE_ME@localhost:5432/doorboard
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
HOME_ASSISTANT_URL=http://localhost:8123
HOME_ASSISTANT_TOKEN=            # long-lived token, scoped, NUC only
CONTROL_PLANE_ADMIN_TOKEN=       # shared bearer secret for /admin/* (stopgap; see packages/auth README)
NTFY_URL=                        # e.g. https://ntfy.sh — empty disables owner notifications (dev/CI default)
NTFY_TOPIC=
CONTROL_PLANE_PRESENCE_HISTORY_MAX_ROWS=500 # presence_history retention cap, per subject_id (T-504)
CONTROL_PLANE_PRESENCE_STALE_AFTER_S=1800   # wallboard staleness hint threshold for the cached presence bundle

# --- NUC: infra/compose (T-503) ---
# LAN_BIND_ADDR: which interface Compose publishes ports on. 0.0.0.0 (every
# interface) is fine for a single-NIC NUC; set to a specific address on a
# dual-homed box. Never port-forward these on the router (handoff §16).
LAN_BIND_ADDR=0.0.0.0
POSTGRES_PASSWORD=CHANGE_ME       # sets the `postgres` container's password (see POSTGRES_DSN note above)
# Mosquitto per-device credentials (infra/compose/mosquitto/). Usernames are
# fixed conventions written into acl.conf (control-plane-api, door-pi,
# home-assistant, ha-discovery, healthcheck) — only these passwords are
# secret. control-plane-api's own MQTT_USERNAME/MQTT_PASSWORD above are
# overridden by Compose to `control-plane-api` / MQTT_CP_PASSWORD; the door
# Pi's own .env (out of git) gets MQTT_PI_PASSWORD copied in only if/when it
# ever needs to publish directly (it doesn't yet — door-sync talks HTTP to
# control-plane-api).
MQTT_CP_PASSWORD=CHANGE_ME
MQTT_PI_PASSWORD=CHANGE_ME
MQTT_HA_PASSWORD=CHANGE_ME
MQTT_HA_DISCOVERY_PASSWORD=CHANGE_ME
MQTT_HEALTHCHECK_PASSWORD=CHANGE_ME
# Postgres backup job (infra/compose/backup/pg-backup.sh) — NAS_BACKUP_PATH
# is a host mount of the NAS backups share (deploy/nas/README.md), never a
# Docker volume, so dumps survive a volume wipe.
NAS_BACKUP_PATH=/mnt/nas/doorboard/backups
BACKUP_INTERVAL_S=86400
BACKUP_RETAIN_COUNT=14
# Optional internal HTTPS (infra/caddy/), off by default (`--profile https`).
# Must be a LAN-only hostname — never a publicly routable domain.
DOORBOARD_INTERNAL_DOMAIN=doorboard.internal

# --- Integrations (all optional, feature-flagged) ---
FEATURE_BIRDNET=false
FEATURE_SATELLITES=false
FEATURE_AIRCRAFT=false
FEATURE_PRINTER=false
FEATURE_FOOD=false
FEATURE_PHOTOBOOTH=false
# NUC wallboard-worker: issue a dedicated ingest-scoped token before enabling
# any production job; do not give the worker CONTROL_PLANE_ADMIN_TOKEN.
WALLBOARD_WORKER_INGEST_TOKEN=
BIRD_PROVIDER=avian_visitors    # avian_visitors | birdnet_go | mock
BIRDNET_CONFIDENCE_THRESHOLD=0.70
BIRDNET_SPECIES_FILTER=         # comma-separated common or scientific names
AVIAN_VISITORS_URL=http://birdnet.local
AVIAN_VISITORS_RECENT_HOURS=24  # rolling window, 1..168
AVIAN_VISITORS_BASIC_USER=      # optional; set user and password together
AVIAN_VISITORS_BASIC_PASSWORD=
AVIAN_VISITORS_TIMEOUT_S=5
BIRDNET_GO_URL=http://birdnet.local:8080 # legacy BirdNET-Go provider only
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
OBSERVER_LAT=                    # for satellite pass calc — NUC only, never shown publicly
OBSERVER_LON=
OBSERVER_ALT_M=
PRINTER_API_URL=
